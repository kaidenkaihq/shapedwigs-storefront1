{% comment %}
  ShapedWigs · Collection mosaic
  File: sections/sw-collection-mosaic.liquid

  Add 5 collection blocks to recreate the homepage mosaic.
  The first block is rendered as the large feature card.
{% endcomment %}

<section class="sw-section sw-section--ivory">
  <div class="sw-container">
    {% if section.settings.heading != blank or section.settings.eyebrow != blank %}
      <div class="sw-section-head">
        {% if section.settings.eyebrow != blank %}
          <span class="sw-eyebrow">{{ section.settings.eyebrow }}</span>
        {% endif %}
        {% if section.settings.heading != blank %}
          <h2>{{ section.settings.heading }}</h2>
        {% endif %}
        {% if section.settings.subheading != blank %}
          <p>{{ section.settings.subheading }}</p>
        {% endif %}
      </div>
    {% endif %}

    <div class="sw-mosaic">
      {% for block in section.blocks %}
        {%- liquid
          assign coll = collections[block.settings.collection]
          assign img = block.settings.image | default: coll.image
          assign first_product_img = coll.products.first.featured_image
          assign final_img = img | default: first_product_img
        -%}

        <a href="{{ coll.url | default: '#' }}"
           class="sw-mosaic-card{% if forloop.first %} sw-mosaic-card--feature{% endif %}"
           {{ block.shopify_attributes }}>

          {% if final_img %}
            <div class="sw-mosaic-bg"
                 style="background-image: url('{{ final_img | image_url: width: 1200 }}');"></div>
          {% endif %}

          <div>
            {% if block.settings.eyebrow != blank %}
              <span class="sw-eyebrow sw-eyebrow--light">{{ block.settings.eyebrow }}</span>
            {% endif %}
            <h3 class="sw-mosaic-title">
              {{ block.settings.title | default: coll.title }}
            </h3>
            <span class="sw-mosaic-link">
              {{ block.settings.link_label | default: 'Shop now' }}
            </span>
          </div>
        </a>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "SW · Collection mosaic",
  "tag": "section",
  "max_blocks": 5,
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Curated collections"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Find your signature."
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Four edits, each crafted for a different mood — from the timeless bridal silhouette to ready-to-wear everyday luxe."
    }
  ],
  "blocks": [
    {
      "type": "collection",
      "name": "Collection card",
      "settings": [
        {
          "type": "collection",
          "id": "collection",
          "label": "Collection"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Override image (optional)",
          "info": "Falls back to the collection image, then to the first product image."
        },
        {
          "type": "text",
          "id": "eyebrow",
          "label": "Eyebrow",
          "default": "Featured"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Card title",
          "info": "Falls back to the collection title."
        },
        {
          "type": "text",
          "id": "link_label",
          "label": "Link label",
          "default": "Shop now"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "SW · Collection mosaic",
      "blocks": [
        { "type": "collection", "settings": { "eyebrow": "Featured", "title": "Best-selling pre-styled wigs", "link_label": "Shop best sellers" } },
        { "type": "collection", "settings": { "eyebrow": "Just landed", "title": "New arrivals", "link_label": "Discover" } },
        { "type": "collection", "settings": { "eyebrow": "Everyday", "title": "Ready to wear", "link_label": "Shop now" } },
        { "type": "collection", "settings": { "eyebrow": "Signature", "title": "Pre-styled wigs", "link_label": "Explore" } },
        { "type": "collection", "settings": { "eyebrow": "Finish the look", "title": "Luxe accessories", "link_label": "Shop" } }
      ]
    }
  ]
}
{% endschema %}
