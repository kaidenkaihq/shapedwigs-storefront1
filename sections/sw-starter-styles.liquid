{% comment %}
  ShapedWigs · Starter styles
  File: sections/sw-starter-styles.liquid

  A curated first-time buyer edit using specific product handles.
{% endcomment %}

{%- assign product_handles = section.settings.product_handles | split: ',' -%}

<section class="sw-section sw-section--ivory sw-starter">
  <div class="sw-container">
    <div class="sw-starter__header">
      <div>
        {% if section.settings.eyebrow != blank %}
          <span class="sw-eyebrow">{{ section.settings.eyebrow }}</span>
        {% endif %}
        {% if section.settings.heading != blank %}
          <h2>{{ section.settings.heading }}</h2>
        {% endif %}
      </div>
      {% if section.settings.subheading != blank %}
        <p>{{ section.settings.subheading }}</p>
      {% endif %}
    </div>

    <div class="sw-starter-grid">
      {%- for raw_handle in product_handles -%}
        {%- liquid
          assign product_handle = raw_handle | strip
          assign featured_product = all_products[product_handle]
        -%}
        {%- if featured_product != blank -%}
          <div class="sw-starter-card">
            {% render 'sw-product-card', product: featured_product, hide_price: false %}
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>

    {% if section.settings.note != blank or section.settings.button_label != blank %}
      <div class="sw-starter__footer">
        {% if section.settings.note != blank %}
          <p>{{ section.settings.note }}</p>
        {% endif %}
        {% if section.settings.button_label != blank and section.settings.button_link != blank %}
          <a class="button button--secondary" href="{{ section.settings.button_link }}">
            {{ section.settings.button_label }}
          </a>
        {% endif %}
      </div>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "SW · Starter styles",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "First-time buyer edit"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Starter Styles Under $500"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "A lower-ticket entry point into handcrafted ShapedWigs: polished, wearable favorites selected for first-time buyers who want a confident start."
    },
    {
      "type": "textarea",
      "id": "product_handles",
      "label": "Product handles",
      "default": "jada,ciara,tasha,franchesca",
      "info": "Comma-separated product handles."
    },
    {
      "type": "textarea",
      "id": "note",
      "label": "Footer note",
      "default": "Each style is still made to order with premium human hair and a 3–4 week lead time."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "View all wigs"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link",
      "default": "/collections/all"
    }
  ],
  "presets": [
    {
      "name": "SW · Starter styles"
    }
  ]
}
{% endschema %}
