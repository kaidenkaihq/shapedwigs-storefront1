{% comment %}
  ShapedWigs · Instagram strip
  File: sections/sw-instagram-strip.liquid

  Uses editable Instagram-style tiles in a horizontal carousel.
{% endcomment %}

<section class="sw-section sw-section--cream" style="padding-bottom: 0;">
  <div class="sw-container">
    <div class="sw-section-head">
      {% if section.settings.eyebrow != blank %}
        <span class="sw-eyebrow">{{ section.settings.eyebrow }}</span>
      {% endif %}
      {% if section.settings.heading != blank %}
        <h2>{{ section.settings.heading }}</h2>
      {% endif %}
      {% if section.settings.subheading != blank %}
        <p>{{ section.settings.subheading }}</p>
      {% endif %}
    </div>
  </div>

  {%- assign fallback_collection = collections[section.settings.fallback_collection] -%}
  {%- assign instagram_profile_url = section.settings.profile_url | default: 'https://www.instagram.com/shapedwigs/' -%}

  <div class="sw-ig-carousel sw-container" id="InstagramCarousel-{{ section.id }}">
    <button class="sw-ig-carousel__button sw-ig-carousel__button--prev" type="button" aria-label="Previous Instagram images">
      <svg aria-hidden="true" focusable="false" viewBox="0 0 12 8">
        <path d="M1 1.2 6 6.8l5-5.6" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </button>
    <div class="sw-ig-carousel__track" tabindex="0" aria-label="Recent ShapedWigs Instagram images">
      {% for block in section.blocks %}
        {%- liquid
          assign fallback_product = fallback_collection.products[forloop.index0]
          assign tile_image = block.settings.image | default: fallback_product.featured_image
        -%}
        <a class="sw-ig-tile"
           href="{{ block.settings.link | default: instagram_profile_url }}"
           target="_blank" rel="noopener"
           {{ block.shopify_attributes }}>
          {% if tile_image %}
            <img src="{{ tile_image | image_url: width: 700 }}"
                 srcset="{{ tile_image | image_url: width: 400 }} 400w,
                         {{ tile_image | image_url: width: 700 }} 700w,
                         {{ tile_image | image_url: width: 900 }} 900w"
                 sizes="(min-width: 990px) 220px, (min-width: 750px) 28vw, 58vw"
                 width="700"
                 height="{{ 700 | divided_by: tile_image.aspect_ratio | round }}"
                 alt="{{ tile_image.alt | default: 'Recent ShapedWigs Instagram styling' }}"
                 loading="lazy">
          {% endif %}
        </a>
      {% endfor %}
    </div>
    <button class="sw-ig-carousel__button sw-ig-carousel__button--next" type="button" aria-label="Next Instagram images">
      <svg aria-hidden="true" focusable="false" viewBox="0 0 12 8">
        <path d="M1 1.2 6 6.8l5-5.6" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </button>
    <p class="sw-ig-carousel__link">
      <a href="{{ instagram_profile_url }}" target="_blank" rel="noopener">
        View more on Instagram
      </a>
    </p>
  </div>

  <script>
    (() => {
      const carousel = document.getElementById('InstagramCarousel-{{ section.id }}');
      if (!carousel) return;

      const track = carousel.querySelector('.sw-ig-carousel__track');
      const previous = carousel.querySelector('.sw-ig-carousel__button--prev');
      const next = carousel.querySelector('.sw-ig-carousel__button--next');
      const step = () => Math.max(track.clientWidth * 0.82, 240);

      previous?.addEventListener('click', () => {
        track.scrollBy({ left: -step(), behavior: 'smooth' });
      });

      next?.addEventListener('click', () => {
        track.scrollBy({ left: step(), behavior: 'smooth' });
      });
    })();
  </script>

  <div style="height: 64px;"></div>
</section>

{% schema %}
{
  "name": "SW · Instagram",
  "tag": "section",
  "max_blocks": 12,
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "@shapedwigs"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "As worn by our community."
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Tag @shapedwigs for a chance to be featured."
    },
    {
      "type": "url",
      "id": "profile_url",
      "label": "Default Instagram profile link",
      "info": "Used for the live Instagram embed and when individual tile links are blank."
    },
    {
      "type": "collection",
      "id": "fallback_collection",
      "label": "Fallback image collection",
      "info": "Used for tiles without an assigned image."
    }
  ],
  "blocks": [
    {
      "type": "tile",
      "name": "Instagram tile",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link to post (optional)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "SW · Instagram",
      "blocks": [
        { "type": "tile" },
        { "type": "tile" },
        { "type": "tile" },
        { "type": "tile" },
        { "type": "tile" },
        { "type": "tile" }
      ]
    }
  ]
}
{% endschema %}
