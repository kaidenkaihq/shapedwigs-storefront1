{% comment %}
  ShapedWigs · Instagram strip
  File: sections/sw-instagram-strip.liquid

  Static image grid styled like an IG feed. For a live feed,
  install a free Shopify Instagram app (e.g. Instafeed, Tagembed)
  and replace this section with the app's section.
{% endcomment %}

<section class="sw-section sw-section--cream" style="padding-bottom: 0;">
  <div class="sw-container">
    <div class="sw-section-head">
      {% if section.settings.eyebrow != blank %}
        <span class="sw-eyebrow">{{ section.settings.eyebrow }}</span>
      {% endif %}
      {% if section.settings.heading != blank %}
        <h2>{{ section.settings.heading }}</h2>
      {% endif %}
      {% if section.settings.subheading != blank %}
        <p>{{ section.settings.subheading }}</p>
      {% endif %}
    </div>
  </div>

  {%- assign fallback_collection = collections[section.settings.fallback_collection] -%}

  <div class="sw-ig-grid">
    {% for block in section.blocks %}
      {%- liquid
        assign fallback_product = fallback_collection.products[forloop.index0]
        assign tile_image = block.settings.image | default: fallback_product.featured_image
      -%}
      <a class="sw-ig-tile"
         href="{{ block.settings.link | default: section.settings.profile_url }}"
         target="_blank" rel="noopener"
         {{ block.shopify_attributes }}>
        {% if tile_image %}
          <img src="{{ tile_image | image_url: width: 600 }}"
               srcset="{{ tile_image | image_url: width: 400 }} 400w,
                       {{ tile_image | image_url: width: 800 }} 800w"
               sizes="(min-width: 769px) 220px, 33vw"
               width="600"
               height="{{ 600 | divided_by: tile_image.aspect_ratio | round }}"
               alt="{{ tile_image.alt | default: 'ShapedWigs community styling' }}"
               loading="lazy">
        {% endif %}
      </a>
    {% endfor %}
  </div>

  <div style="height: 64px;"></div>
</section>

{% schema %}
{
  "name": "SW · Instagram",
  "tag": "section",
  "max_blocks": 6,
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "@shapedwigs"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "As worn by our community."
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Tag @shapedwigs for a chance to be featured."
    },
    {
      "type": "url",
      "id": "profile_url",
      "label": "Default Instagram profile link",
      "info": "Used when individual tile links are blank."
    },
    {
      "type": "collection",
      "id": "fallback_collection",
      "label": "Fallback image collection",
      "info": "Used for tiles without an assigned image."
    }
  ],
  "blocks": [
    {
      "type": "tile",
      "name": "Instagram tile",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link to post (optional)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "SW · Instagram",
      "blocks": [
        { "type": "tile" },
        { "type": "tile" },
        { "type": "tile" },
        { "type": "tile" },
        { "type": "tile" },
        { "type": "tile" }
      ]
    }
  ]
}
{% endschema %}
